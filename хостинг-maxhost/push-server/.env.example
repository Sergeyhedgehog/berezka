# ──────────────────────────────────────────────────────────────────
# Берёзка Push Server — конфигурация
# Скопируйте этот файл в .env и заполните значения
# ──────────────────────────────────────────────────────────────────

# URL Firebase Realtime Database (из Firebase Console → Realtime Database)
# Пример: https://berezka-4a2c5-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_URL=https://berezka-4a2c5-default-rtdb.europe-west1.firebasedatabase.app

# VAPID-ключи (сгенерировать: python3 generate_vapid.py)
VAPID_PUBLIC_KEY=ЗАПОЛНИТЬ_ПОСЛЕ_generate_vapid.py
VAPID_PRIVATE_KEY=ЗАПОЛНИТЬ_ПОСЛЕ_generate_vapid.py

# Ваш email (нужен для VAPID claims, любой валидный адрес)
VAPID_EMAIL=admin@yourdomain.ru
